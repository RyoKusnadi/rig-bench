{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "node hooks/pre-bash-safety.mjs"
          }
        ]
      }
    ]
  },
  "permissions": {
    "defaultMode": "auto",
    "allow": [
      "Bash",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "Read",
      "NotebookEdit",
      "WebFetch",
      "WebSearch",
      "Command(plan)"
    ]
  }
}
