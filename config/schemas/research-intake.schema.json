{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "research-intake",
  "type": "object",
  "required": ["topic", "focus_areas", "target_outcome", "constraints", "depth", "validation_threshold", "max_iterations"],
  "properties": {
    "topic": { "type": "string" },
    "focus_areas": { "type": "array", "items": { "type": "string" } },
    "current_baseline": { "type": "string" },
    "target_outcome": {
      "type": "string",
      "enum": ["implementation_guide", "architectural_comparison", "migration_steps", "deep_dive_reference"]
    },
    "constraints": {
      "type": "object",
      "required": ["version_policy"],
      "properties": {
        "tech_stack": { "type": "array", "items": { "type": "string" } },
        "version_policy": { "type": "string", "enum": ["latest_stable", "lts_only", "bleeding_edge"] },
        "must_include": { "type": "array", "items": { "type": "string" } },
        "must_exclude": { "type": "array", "items": { "type": "string" } }
      }
    },
    "depth": { "type": "string", "enum": ["high_level_overview", "moderate_detail", "code_heavy_deep_dive"] },
    "validation_threshold": { "type": "number" },
    "max_iterations": { "type": "number" }
  }
}
