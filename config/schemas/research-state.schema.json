{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "research-state",
  "type": "object",
  "required": ["questionnaire", "current_hypothesis", "validated_facts", "confidence_score", "iteration_count", "loop_log", "completed"],
  "properties": {
    "questionnaire": { "type": "object" },
    "current_hypothesis": { "type": "string" },
    "validated_facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_url", "extracted_fact", "validation_status"],
        "properties": {
          "source_url": { "type": "string" },
          "extracted_fact": { "type": "string" },
          "validation_status": { "type": "string", "enum": ["verified", "pending", "debunked"] },
          "validation_method": { "type": "string" }
        }
      }
    },
    "next_search_query": { "type": "string" },
    "confidence_score": { "type": "number" },
    "iteration_count": { "type": "number" },
    "loop_log": { "type": "array", "items": { "type": "string" } },
    "completed": { "type": "boolean" }
  }
}
